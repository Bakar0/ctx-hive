{
  "name": "ctx-hive",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "ctx-hive": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile ctx-hive",
    "build:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile ctx-hive-linux-x64",
    "deploy": "bun run build && sudo cp ctx-hive /usr/local/bin/ctx-hive",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
