{
  "name": "ctx-hive",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "bin": {
    "ctx-hive": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build ./src/index.ts --compile --outfile ctx-hive",
    "build:linux-x64": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile ctx-hive-linux-x64",
    "deploy": "bun run build && cp ctx-hive ~/.local/bin/ctx-hive",
    "lint": "oxlint --type-aware",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "oxlint": "^1.56.0",
    "oxlint-tsgolint": "^0.17.1",
    "typescript": "^5"
  },
  "dependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "zod": "^4.3.6"
  }
}
